---
interface Props {
	name: string;
	description: string;
	avatar: string;
	url: string;
	style?: string;
}

const { name, description, avatar, url, style } = Astro.props;
---
<a href={url} target="_blank" rel="noopener noreferrer"
   class="group block rounded-[var(--radius-large)] p-4 transition-all duration-300 active:scale-[0.98] onload-animation relative overflow-hidden bg-[var(--card-bg)] border border-white/5"
   style={style}>

    <!-- 毛玻璃背景效果：悬浮时背景颜色变淡并模糊 -->
    <div class="absolute inset-0 bg-[var(--primary)]/0 group-hover:bg-[var(--primary)]/5 group-hover:backdrop-blur-md transition-all duration-500"></div>

    <div class="flex items-center gap-5 relative z-10">
        <div class="relative shrink-0">
            <!-- 错位衬底：头像后的半透明装饰块 -->
            <div class="absolute inset-0 bg-[var(--primary)] rounded-xl opacity-0 -translate-x-1 -translate-y-1 group-hover:opacity-30 group-hover:-translate-x-2 group-hover:-translate-y-2 transition-all duration-500"></div>

            <!-- 头像：圆角矩形 -->
            <img src={avatar} alt={name}
                 class="w-16 h-16 rounded-xl object-cover relative z-10 shadow-md transition-transform duration-500 group-hover:-translate-x-0.5 group-hover:-translate-y-0.5"/>
        </div>

        <div class="flex-grow min-w-0">
            <div class="relative inline-block">
                <div class="font-bold text-lg text-90 truncate group-hover:text-[var(--primary)] transition-colors duration-300">
                    {name}
                </div>
                <!-- 动态下划线 -->
                <div class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[var(--primary)] transition-all duration-500 group-hover:w-full"></div>
            </div>
            <div class="text-75 text-sm line-clamp-2 mt-2 h-10 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">
                {description}
            </div>
        </div>
    </div>
</a>
