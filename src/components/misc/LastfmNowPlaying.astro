---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
---

<span
  data-lastfm-now-playing
  data-loading-label={i18n(I18nKey.lastfmLoading)}
  data-refreshing-label={i18n(I18nKey.lastfmRefreshing)}
  data-empty-label={i18n(I18nKey.lastfmNoSong)}
  data-error-label={i18n(I18nKey.lastfmUnavailable)}
  aria-live="polite"
>
  <span data-lastfm-content class="now-playing">{i18n(I18nKey.lastfmLoading)}</span>
</span>

<script>
type LastfmPlayer = {
	isPlaying: boolean;
	songUrl?: string;
	title?: string;
	artist?: string;
};

function renderMessage(
	container: HTMLElement,
	text: string,
	className = "now-playing",
): void {
	const span = document.createElement("span");
	span.className = className;
	span.textContent = text;
	container.replaceChildren(span);
}

function renderPlayer(container: HTMLElement, player: LastfmPlayer): void {
	if (player.isPlaying && player.songUrl && player.title && player.artist) {
		const link = document.createElement("a");
		link.className = "now-playing";
		link.href = player.songUrl;
		link.textContent = `${player.title} - ${player.artist}`;
		container.replaceChildren(link);
		return;
	}

	renderMessage(
		container,
		container.parentElement?.dataset.emptyLabel ||
			"No song at the moment — enjoying the silence.",
	);
}

async function loadPlayer(root: HTMLElement, initial: boolean): Promise<void> {
	const content = root.querySelector("[data-lastfm-content]");
	if (!(content instanceof HTMLElement)) {
		return;
	}

	if (!initial) {
		renderMessage(
			content,
			root.dataset.refreshingLabel || "Refreshing...",
			"loading-indicator",
		);
	}

	try {
		const response = await fetch("/api/lastfm.json");
		if (!response.ok) {
			renderMessage(
				content,
				root.dataset.errorLabel || "Last.fm is currently unavailable.",
			);
			return;
		}

		const player = (await response.json()) as LastfmPlayer;
		renderPlayer(content, player);
	} catch {
		renderMessage(
			content,
			root.dataset.errorLabel || "Last.fm is currently unavailable.",
		);
	}
}

function initLastfmNowPlaying(root: Element): void {
	if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") {
		return;
	}
	root.dataset.initialized = "true";

	void loadPlayer(root, true);
	const intervalId = window.setInterval(() => {
		if (!root.isConnected) {
			window.clearInterval(intervalId);
			return;
		}
		void loadPlayer(root, false);
	}, 30000);
}

function initLastfmNowPlayingComponents(): void {
	document.querySelectorAll("[data-lastfm-now-playing]").forEach(initLastfmNowPlaying);
}

if (document.readyState === "loading") {
	document.addEventListener(
		"DOMContentLoaded",
		initLastfmNowPlayingComponents,
		{ once: true },
	);
} else {
	initLastfmNowPlayingComponents();
}

document.addEventListener("astro:page-load", initLastfmNowPlayingComponents);
</script>
