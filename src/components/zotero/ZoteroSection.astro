---
import type { ZoteroItem } from "@/types/zotero";
import ZoteroCard from "./ZoteroCard.astro";
import FilterControls from "../bangumi/FilterControls.astro";

interface Props {
	sectionId: string;
	items: ZoteroItem[];
	isActive: boolean;
	itemsPerPage?: number;
}

const { sectionId, items, isActive, itemsPerPage = 12 } = Astro.props;

// Get type filters with counts
const typeCounts = items.reduce(
	(acc, item) => {
		const type = item.data.itemType || "unknown";
		acc[type] = (acc[type] || 0) + 1;
		return acc;
	},
	{} as Record<string, number>,
);

const typeLabels: Record<string, string> = {
	book: "书籍",
	bookSection: "章节",
	journalArticle: "期刊论文",
	magazineArticle: "杂志文章",
	newspaperArticle: "报纸文章",
	thesis: "学位论文",
	letter: "书信",
	manuscript: "手稿",
	interview: "访谈",
	film: "电影",
	tvBroadcast: "电视广播",
	radioBroadcast: "广播",
	podcast: "播客",
	videoRecording: "视频录制",
	audioRecording: "录音",
	webpage: "网页",
	software: "软件",
	report: "报告",
	statute: "法令",
	bill: "法案",
	case: "案例",
	hearing: "听证会",
	patent: "专利",
	map: "地图",
	artwork: "艺术品",
	presentation: "演示文稿",
	instantMessage: "即时消息",
	forumPost: "论坛帖子",
	blogPost: "博客文章",
	email: "电子邮件",
	computerProgram: "计算机程序",
	conferencePaper: "会议论文",
	dictionaryEntry: "词典条目",
	encyclopediaArticle: "百科全书文章",
	preprint: "预印本",
	standard: "标准",
	document: "文档",
	unknown: "其他",
};

const filters = [
	{ value: "all", label: "全部", count: items.length },
	...Object.entries(typeCounts)
		.map(([type, count]) => ({
			value: type,
			label: typeLabels[type] || type,
			count,
		}))
		.sort((a, b) => b.count - a.count), // 按数量降序排列
];

const defaultFilter = "all";
---

<div class:list={["zotero-section", { "hidden": !isActive }]} data-section={sectionId}>
  {items.length > 0 ? (
    <>
      <FilterControls
        filters={filters}
        activeFilter={defaultFilter}
        sectionId={sectionId}
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item, index) => (
          <div
            class="zotero-item h-full transition-all duration-500 animate-fade-in"
            data-item-section={sectionId}
            data-item-status={item.data.itemType || "unknown"}
            style={index >= itemsPerPage ? "display: none;" : ""}
          >
            <ZoteroCard item={item} />
          </div>
        ))}
      </div>
    </>
  ) : (
    <div class="text-center py-12">
      <h3 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-2">暂无数据</h3>
      <p class="text-gray-500 dark:text-gray-500">无法从 Zotero 获取到任何文献条目</p>
    </div>
  )}
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
</style>
