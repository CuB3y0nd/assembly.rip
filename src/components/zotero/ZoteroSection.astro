---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { ZoteroItem } from "@/types/zotero";
import FilterControls from "../bangumi/FilterControls.astro";
import ZoteroCard from "./ZoteroCard.astro";

interface Props {
	sectionId: string;
	items: ZoteroItem[];
	isActive: boolean;
	itemsPerPage?: number;
}

const { sectionId, items, isActive, itemsPerPage = 12 } = Astro.props;

// Get type filters with counts
const typeCounts = items.reduce(
	(acc, item) => {
		const type = item.data.itemType || "unknown";
		acc[type] = (acc[type] || 0) + 1;
		return acc;
	},
	{} as Record<string, number>,
);

const typeLabels: Record<string, string> = {
	book: i18n(I18nKey.zoteroBook),
	bookSection: i18n(I18nKey.zoteroBookSection),
	journalArticle: i18n(I18nKey.zoteroJournalArticle),
	magazineArticle: i18n(I18nKey.zoteroMagazineArticle),
	newspaperArticle: i18n(I18nKey.zoteroNewspaperArticle),
	thesis: i18n(I18nKey.zoteroThesis),
	letter: i18n(I18nKey.zoteroLetter),
	manuscript: i18n(I18nKey.zoteroManuscript),
	interview: i18n(I18nKey.zoteroInterview),
	film: i18n(I18nKey.zoteroFilm),
	tvBroadcast: i18n(I18nKey.zoteroTvBroadcast),
	radioBroadcast: i18n(I18nKey.zoteroRadioBroadcast),
	podcast: i18n(I18nKey.zoteroPodcast),
	videoRecording: i18n(I18nKey.zoteroVideoRecording),
	audioRecording: i18n(I18nKey.zoteroAudioRecording),
	webpage: i18n(I18nKey.zoteroWebpage),
	software: i18n(I18nKey.zoteroSoftware),
	report: i18n(I18nKey.zoteroReport),
	statute: i18n(I18nKey.zoteroStatute),
	bill: i18n(I18nKey.zoteroBill),
	case: i18n(I18nKey.zoteroCase),
	hearing: i18n(I18nKey.zoteroHearing),
	patent: i18n(I18nKey.zoteroPatent),
	map: i18n(I18nKey.zoteroMap),
	artwork: i18n(I18nKey.zoteroArtwork),
	presentation: i18n(I18nKey.zoteroPresentation),
	instantMessage: i18n(I18nKey.zoteroInstantMessage),
	forumPost: i18n(I18nKey.zoteroForumPost),
	blogPost: i18n(I18nKey.zoteroBlogPost),
	email: i18n(I18nKey.zoteroEmail),
	computerProgram: i18n(I18nKey.zoteroComputerProgram),
	conferencePaper: i18n(I18nKey.zoteroConferencePaper),
	dictionaryEntry: i18n(I18nKey.zoteroDictionaryEntry),
	encyclopediaArticle: i18n(I18nKey.zoteroEncyclopediaArticle),
	preprint: i18n(I18nKey.zoteroPreprint),
	standard: i18n(I18nKey.zoteroStandard),
	document: i18n(I18nKey.zoteroDocument),
	unknown: i18n(I18nKey.zoteroUnknown),
};

const filters = [
	{ value: "all", label: i18n(I18nKey.zoteroAll), count: items.length },
	...Object.entries(typeCounts)
		.map(([type, count]) => ({
			value: type,
			label: typeLabels[type] || type,
			count,
		}))
		.sort((a, b) => b.count - a.count), // 按数量降序排列
];

const defaultFilter = "all";
---

<div
  class:list={["zotero-section", { "hidden": !isActive }]}
  data-collections-section={sectionId}
>
  {items.length > 0 ? (
    <>
      <FilterControls
        filters={filters}
        activeFilter={defaultFilter}
        sectionId={sectionId}
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item, index) => (
          <div
            class="zotero-item h-full transition-all duration-500 animate-fade-in"
            data-item-section={sectionId}
            data-item-status={item.data.itemType || "unknown"}
            style={index >= itemsPerPage ? "display: none;" : ""}
          >
            <ZoteroCard item={item} />
          </div>
        ))}
      </div>
    </>
  ) : (
    <div class="text-center py-12">
      <h3 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-2">{i18n(I18nKey.zoteroNoData)}</h3>
      <p class="text-gray-500 dark:text-gray-500">{i18n(I18nKey.zoteroFetchError)}</p>
    </div>
  )}
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
</style>
