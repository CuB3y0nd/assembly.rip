---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { ZoteroItem } from "@/types/zotero";

interface Props {
	item: ZoteroItem;
}

const { item } = Astro.props;
const { data } = item;

const getIconName = (type: string) => {
	const iconMap: Record<string, string> = {
		book: "tabler:book",
		bookSection: "tabler:book-2",
		journalArticle: "tabler:file-text",
		magazineArticle: "tabler:article",
		newspaperArticle: "tabler:news",
		thesis: "tabler:school",
		letter: "tabler:mail",
		manuscript: "tabler:scroll",
		interview: "tabler:microphone",
		film: "tabler:movie",
		tvBroadcast: "tabler:device-tv",
		radioBroadcast: "tabler:radio",
		podcast: "tabler:podcast",
		videoRecording: "tabler:video",
		audioRecording: "tabler:volume-2",
		webpage: "tabler:world",
		software: "tabler:terminal-2",
		report: "tabler:report-analytics",
		statute: "tabler:gavel",
		bill: "tabler:file-description",
		case: "tabler:building-bank",
		hearing: "tabler:ear",
		patent: "tabler:bulb",
		map: "tabler:map-2",
		artwork: "tabler:palette",
		presentation: "tabler:presentation",
		instantMessage: "tabler:messages",
		forumPost: "tabler:message-circle",
		blogPost: "tabler:edit",
		email: "tabler:at",
		computerProgram: "tabler:code",
		conferencePaper: "tabler:users-group",
		dictionaryEntry: "tabler:vocabulary",
		encyclopediaArticle: "tabler:books",
		preprint: "tabler:microscope",
		standard: "tabler:certificate",
		document: "tabler:file",
	};
	return iconMap[type] || "tabler:bookmark";
};

const getTypeLabel = (type: string) => {
	const labelMap: Record<string, I18nKey> = {
		book: I18nKey.zoteroBook,
		bookSection: I18nKey.zoteroBookSection,
		journalArticle: I18nKey.zoteroJournalArticle,
		magazineArticle: I18nKey.zoteroMagazineArticle,
		newspaperArticle: I18nKey.zoteroNewspaperArticle,
		thesis: I18nKey.zoteroThesis,
		letter: I18nKey.zoteroLetter,
		manuscript: I18nKey.zoteroManuscript,
		interview: I18nKey.zoteroInterview,
		film: I18nKey.zoteroFilm,
		tvBroadcast: I18nKey.zoteroTvBroadcast,
		radioBroadcast: I18nKey.zoteroRadioBroadcast,
		podcast: I18nKey.zoteroPodcast,
		videoRecording: I18nKey.zoteroVideoRecording,
		audioRecording: I18nKey.zoteroAudioRecording,
		webpage: I18nKey.zoteroWebpage,
		software: I18nKey.zoteroSoftware,
		report: I18nKey.zoteroReport,
		statute: I18nKey.zoteroStatute,
		bill: I18nKey.zoteroBill,
		case: I18nKey.zoteroCase,
		hearing: I18nKey.zoteroHearing,
		patent: I18nKey.zoteroPatent,
		map: I18nKey.zoteroMap,
		artwork: I18nKey.zoteroArtwork,
		presentation: I18nKey.zoteroPresentation,
		instantMessage: I18nKey.zoteroInstantMessage,
		forumPost: I18nKey.zoteroForumPost,
		blogPost: I18nKey.zoteroBlogPost,
		email: I18nKey.zoteroEmail,
		computerProgram: I18nKey.zoteroComputerProgram,
		conferencePaper: I18nKey.zoteroConferencePaper,
		dictionaryEntry: I18nKey.zoteroDictionaryEntry,
		encyclopediaArticle: I18nKey.zoteroEncyclopediaArticle,
		preprint: I18nKey.zoteroPreprint,
		standard: I18nKey.zoteroStandard,
		document: I18nKey.zoteroDocument,
	};
	const key = labelMap[type];
	return key ? i18n(key) : i18n(I18nKey.zoteroUnknown);
};

const creatorList =
	data.creators?.map(
		(c) => c.name || `${c.lastName}${c.firstName ? `, ${c.firstName}` : ""}`,
	) || [];

const creatorSummary =
	creatorList.length <= 2
		? creatorList.join(", ")
		: `${creatorList.slice(0, 2).join(", ")} +${creatorList.length - 2}`;
const abstractNote = data.abstractNote?.replace(/\s+/g, " ").trim() || "";
const sourceLabel = data.publisher || data.publicationTitle || "";

const isPaper = [
	"journalArticle",
	"conferencePaper",
	"preprint",
	"standard",
	"report",
	"thesis",
].includes(data.itemType);
const href = isPaper ? data.url || item.links.alternate.href : undefined;
---

{href ? (
	<a
		href={href}
		target="_blank"
		rel="noopener noreferrer nofollow"
		class="collection-card card-base group h-full flex flex-col min-h-[19.5rem] cursor-pointer"
	>
		<div class="collection-card-body">
			<div class="collection-card-header">
				<div class="collection-card-icon">
					<Icon name={getIconName(data.itemType)} class="text-[1.3rem]" />
				</div>

				{data.date && <span class="collection-card-date">{data.date}</span>}
			</div>

			<div class="collection-card-type">{getTypeLabel(data.itemType)}</div>

			<h3 class="collection-card-title">{data.title}</h3>

			{creatorSummary && <p class="collection-card-authors">{creatorSummary}</p>}

			<p class:list={["collection-card-summary", { "is-empty": !abstractNote }]}>
				{abstractNote || i18n(I18nKey.zoteroNoAbstract)}
			</p>

			<div class="collection-card-footer">
				{sourceLabel ? (
					<div class="collection-card-source">
						<Icon name="tabler:building" class="text-[0.9rem] shrink-0" />
						<span class="truncate">{sourceLabel}</span>
					</div>
				) : (
					<span></span>
				)}

				<div class="collection-card-link-hint">
					<span>Open</span>
					<Icon
						name="material-symbols:arrow-outward-rounded"
						class="text-[1rem]"
					/>
				</div>
			</div>
		</div>
	</a>
) : (
	<div class="collection-card card-base h-full flex flex-col min-h-[19.5rem] cursor-default">
		<div class="collection-card-body">
			<div class="collection-card-header">
				<div class="collection-card-icon">
					<Icon name={getIconName(data.itemType)} class="text-[1.3rem]" />
				</div>

				{data.date && <span class="collection-card-date">{data.date}</span>}
			</div>

			<div class="collection-card-type">{getTypeLabel(data.itemType)}</div>

			<h3 class="collection-card-title">{data.title}</h3>

			{creatorSummary && <p class="collection-card-authors">{creatorSummary}</p>}

			<p class:list={["collection-card-summary", { "is-empty": !abstractNote }]}>
				{abstractNote || i18n(I18nKey.zoteroNoAbstract)}
			</p>

			{sourceLabel && (
				<div class="collection-card-footer">
					<div class="collection-card-source">
						<Icon name="tabler:building" class="text-[0.9rem] shrink-0" />
						<span class="truncate">{sourceLabel}</span>
					</div>
				</div>
			)}
		</div>
	</div>
)}

<style>
	.collection-card {
		overflow: hidden;
		border: 1px solid var(--line-color);
		border-radius: calc(var(--radius-large) + 0.1rem);
		box-shadow: 0 18px 40px -34px rgb(0 0 0 / 0.35);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.collection-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--primary) 18%, var(--line-color));
		box-shadow: 0 24px 48px -36px rgb(0 0 0 / 0.42);
	}

	.collection-card-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		gap: 0.55rem;
		padding: 1.1rem;
	}

	.collection-card-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.9rem;
	}

	.collection-card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 0.85rem;
		background: var(--btn-regular-bg);
		color: var(--primary);
	}

	.collection-card-date {
		display: inline-flex;
		align-items: center;
		height: 1.8rem;
		padding: 0 0.6rem;
		border-radius: 0.65rem;
		background: rgb(0 0 0 / 0.04);
		color: rgb(0 0 0 / 0.42);
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1;
	}

	.collection-card-type {
		display: inline-flex;
		align-self: flex-start;
		align-items: center;
		height: 1.8rem;
		padding: 0 0.65rem;
		border-radius: 0.65rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.75rem;
		font-weight: 600;
		line-height: 1;
	}

	.collection-card-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.42;
		color: rgb(0 0 0 / 0.82);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-authors {
		font-size: 0.8rem;
		line-height: 1.55;
		color: rgb(0 0 0 / 0.46);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-summary {
		font-size: 0.85rem;
		line-height: 1.7;
		color: rgb(0 0 0 / 0.62);
		display: -webkit-box;
		-webkit-line-clamp: 5;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-summary.is-empty {
		font-style: italic;
		color: rgb(0 0 0 / 0.38);
	}

	.collection-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid var(--line-divider);
	}

	.collection-card-source {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		flex: 1;
		min-width: 0;
		overflow: hidden;
		color: rgb(0 0 0 / 0.4);
		font-size: 0.74rem;
		font-weight: 500;
	}

	.collection-card-source span {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.collection-card-link-hint {
		display: inline-flex;
		align-items: center;
		gap: 0.18rem;
		margin-left: auto;
		flex-shrink: 0;
		color: rgb(0 0 0 / 0.34);
		font-size: 0.72rem;
		font-weight: 600;
		transition: color 180ms ease, transform 180ms ease;
	}

	.collection-card:hover .collection-card-link-hint {
		color: var(--primary);
		transform: translateX(1px);
	}

	:global(.dark) .collection-card {
		box-shadow: none;
	}

	:global(.dark) .collection-card-title {
		color: rgb(255 255 255 / 0.86);
	}

	:global(.dark) .collection-card-date {
		background: rgb(255 255 255 / 0.06);
		color: rgb(255 255 255 / 0.42);
	}

	:global(.dark) .collection-card-authors {
		color: rgb(255 255 255 / 0.46);
	}

	:global(.dark) .collection-card-summary {
		color: rgb(255 255 255 / 0.62);
	}

	:global(.dark) .collection-card-summary.is-empty {
		color: rgb(255 255 255 / 0.34);
	}

	:global(.dark) .collection-card-source {
		color: rgb(255 255 255 / 0.38);
	}

	:global(.dark) .collection-card-link-hint {
		color: rgb(255 255 255 / 0.32);
	}
</style>
