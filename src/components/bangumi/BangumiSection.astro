---
import type { UserSubjectCollection } from "@/types/bangumi";
import Card from "./Card.astro";
import FilterControls from "./FilterControls.astro";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";

interface Props {
	sectionId: string;
	items: UserSubjectCollection[];
	isActive: boolean;
	itemsPerPage?: number;
	subjectType?: number;
}

const {
	sectionId,
	items,
	isActive,
	itemsPerPage = 12,
	subjectType,
} = Astro.props;

const statusMap = {
	1: "wish",
	2: "collect",
	3: "doing",
	4: "on_hold",
	5: "dropped",
};

// Get status filters with counts
const statusCounts = items.reduce(
	(acc, item) => {
		const status = statusMap[item.type as keyof typeof statusMap] || "unknown";
		acc[status] = (acc[status] || 0) + 1;
		return acc;
	},
	{} as Record<string, number>,
);

const isGame = subjectType === 4;
const isReal = subjectType === 6;

const getStatusLabel = (status: string) => {
	if (status === "all") return i18n(I18nKey.bangumiAll);

	if (isGame) {
		const map: Record<string, I18nKey> = {
			collect: I18nKey.bangumiGameCompleted,
			doing: I18nKey.bangumiGameInProgress,
			wish: I18nKey.bangumiGameWish,
			on_hold: I18nKey.bangumiGameOnHold,
			dropped: I18nKey.bangumiGameDropped,
		};
		return i18n(map[status]);
	}
	if (isReal) {
		const map: Record<string, I18nKey> = {
			collect: I18nKey.bangumiRealCompleted,
			doing: I18nKey.bangumiRealInProgress,
			wish: I18nKey.bangumiRealWish,
			on_hold: I18nKey.bangumiRealOnHold,
			dropped: I18nKey.bangumiRealDropped,
		};
		return i18n(map[status]);
	}

	// Default (Anime/Other)
	const map: Record<string, I18nKey> = {
		collect: I18nKey.bangumiCompleted,
		doing: I18nKey.bangumiInProgress,
		wish: I18nKey.bangumiWish,
		on_hold: I18nKey.bangumiOnHold,
		dropped: I18nKey.bangumiDropped,
	};
	return i18n(map[status]);
};

const filters = [
	{ value: "all", label: getStatusLabel("all"), count: items.length },
	{ value: "collect", label: getStatusLabel("collect"), count: statusCounts.collect || 0 },
	{ value: "doing", label: getStatusLabel("doing"), count: statusCounts.doing || 0 },
	{ value: "wish", label: getStatusLabel("wish"), count: statusCounts.wish || 0 },
	{ value: "on_hold", label: getStatusLabel("on_hold"), count: statusCounts.on_hold || 0 },
	{ value: "dropped", label: getStatusLabel("dropped"), count: statusCounts.dropped || 0 },
].filter((filter) => filter.value === "all" || filter.count > 0);

const defaultFilter = "all";
---

<div class:list={["bangumi-section", { "hidden": !isActive }]} data-section={sectionId}>
  {items.length > 0 ? (
    <>
      <FilterControls
        filters={filters}
        activeFilter={defaultFilter}
        sectionId={sectionId}
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
        {items.map((item, index) => (
          <div
            class="bangumi-item"
            data-item-section={sectionId}
            data-item-status={statusMap[item.type as keyof typeof statusMap] || "unknown"}
            style={index >= itemsPerPage ? "display: none;" : ""}
          >
            <Card item={item} subjectType={subjectType} />
          </div>
        ))}
      </div>
    </>
  ) : (
    <div class="text-center py-12">
      <h3 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-2">{i18n(I18nKey.bangumiNoData)}</h3>
      <p class="text-gray-500 dark:text-gray-500">{i18n(I18nKey.bangumiNoItems)}</p>
    </div>
  )}
</div>