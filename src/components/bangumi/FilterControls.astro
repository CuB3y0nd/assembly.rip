---
interface Filter {
	value: string;
	label: string;
	count?: number;
}

interface Props {
	filters: Filter[];
	activeFilter: string;
	sectionId: string;
}

const { filters, activeFilter, sectionId } = Astro.props;
---

<div class="collections-filter-group" data-filter-root={sectionId}>
  {filters.map((filter) => (
    <button
      class="collections-filter-button btn-regular h-7 text-[0.8125rem] px-2.5 rounded-lg"
      data-filter={filter.value}
      data-filter-section={sectionId}
      data-active={filter.value === activeFilter ? "true" : "false"}
      aria-pressed={filter.value === activeFilter ? "true" : "false"}
      type="button"
    >
      <span>{filter.label}</span>
      {filter.count !== undefined && (
        <span class="collections-filter-count">{filter.count}</span>
      )}
    </button>
  ))}
</div>

<script is:inline define:vars={{ sectionId }}>
  function initFilterControls() {
    const root = document.querySelector(`[data-filter-root="${sectionId}"]`);
    if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") {
      return;
    }

    root.dataset.initialized = "true";

    root.addEventListener("click", (event) => {
      const button = event.target instanceof Element
        ? event.target.closest(`[data-filter-section="${sectionId}"][data-filter]`)
        : null;
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const filter = button.dataset.filter || "all";
      const sectionButtons = root.querySelectorAll(`[data-filter-section="${sectionId}"][data-filter]`);
      sectionButtons.forEach((btn) => {
        const isActive = btn === button;
        btn.setAttribute("data-active", String(isActive));
        btn.setAttribute("aria-pressed", String(isActive));
      });

      const items = document.querySelectorAll(`[data-item-section="${sectionId}"]`);
      items.forEach((item) => {
        const htmlItem = item;
        const itemStatus = htmlItem.dataset.itemStatus;
        const isVisible = filter === "all" || itemStatus === filter;

        htmlItem.classList.toggle("hidden", !isVisible);
        htmlItem.style.display = isVisible ? "block" : "none";
      });

      updatePagination(sectionId);
    });
  }

  function updatePagination(sectionId) {
    const visibleItems = document.querySelectorAll(`[data-item-section="${sectionId}"]:not(.hidden)`);
    const pagination = document.querySelector(`[data-pagination-section="${sectionId}"]`);

    if (pagination) {
      // Trigger pagination update
      const event = new CustomEvent('updatePagination', {
        detail: { visibleCount: visibleItems.length }
      });
      pagination.dispatchEvent(event);
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilterControls);
  } else {
    initFilterControls();
  }
</script>

<style>
  .collections-filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 1rem;
  }

  .collections-filter-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      box-shadow 150ms ease;
  }

  .collections-filter-button[data-active="true"] {
    color: var(--primary);
    background: var(--btn-regular-bg-hover);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--primary) 24%, transparent);
  }

  .collections-filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.15rem;
    height: 1.15rem;
    padding: 0 0.28rem;
    border-radius: 0.45rem;
    background: rgb(0 0 0 / 0.05);
    color: inherit;
    opacity: 0.76;
    font-size: 0.67rem;
    font-weight: 600;
    line-height: 1;
    transition: background-color 150ms ease, opacity 150ms ease;
  }

  .collections-filter-button[data-active="true"] .collections-filter-count {
    background: color-mix(in oklab, var(--primary) 16%, transparent);
    opacity: 0.92;
  }

  :global(.dark) .collections-filter-count {
    background: rgb(255 255 255 / 0.08);
  }

  :global(.dark) .collections-filter-button[data-active="true"] {
    color: var(--primary);
  }
</style>
