---
interface Tab {
	id: string;
	name: string;
	count?: number;
}

interface Props {
	tabs: Tab[];
	activeTab: string;
}

const { tabs, activeTab } = Astro.props;
---

<div class="border-b border-gray-200 dark:border-gray-700 mb-3 overflow-x-auto no-scrollbar">
  <nav class="flex space-x-8 min-w-max" aria-label="Tabs" data-tab-nav-root>
    {tabs.map((tab) => (
      <button
        class="collections-tab-button"
        data-tab={tab.id}
        data-active={tab.id === activeTab ? "true" : "false"}
        aria-selected={tab.id === activeTab ? "true" : "false"}
        type="button"
      >
        <span>{tab.name}</span>
        {tab.count !== undefined && (
          <span class="collections-tab-count">
            {tab.count}
          </span>
        )}
      </button>
    ))}
  </nav>
</div>

<script>
  function initTabNavigation() {
    const root = document.querySelector('[data-tab-nav-root]');
    if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") {
      return;
    }

    root.dataset.initialized = "true";

    root.addEventListener("click", (event) => {
      const currentButton = event.target instanceof Element
        ? event.target.closest("[data-tab]")
        : null;
      if (!(currentButton instanceof HTMLButtonElement)) {
        return;
      }

      const targetTab = currentButton.dataset.tab;
      const tabButtons = root.querySelectorAll("[data-tab]");
      const sections = document.querySelectorAll("[data-collections-section]");

      tabButtons.forEach((btn) => {
        const isActive = btn === currentButton;
        btn.setAttribute("data-active", String(isActive));
        btn.setAttribute("aria-selected", String(isActive));
      });

      sections.forEach((section) => {
        if (!(section instanceof HTMLElement)) {
          return;
        }

        const htmlSection = section;
        htmlSection.classList.toggle(
          "hidden",
          htmlSection.dataset.collectionsSection !== targetTab,
        );
      });
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabNavigation);
  } else {
    initTabNavigation();
  }
</script>

<style>
  .collections-tab-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 1rem 0.1rem 0.9rem;
    border-bottom: 2px solid transparent;
    color: rgb(0 0 0 / 0.52);
    font-size: 0.92rem;
    font-weight: 500;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }

  .collections-tab-button:hover {
    color: rgb(0 0 0 / 0.74);
    border-color: var(--line-color);
  }

  .collections-tab-button[data-active="true"] {
    color: var(--primary);
    border-color: var(--primary);
  }

  .collections-tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.7rem;
    height: 1.6rem;
    padding: 0 0.5rem;
    border-radius: 0.6rem;
    background: var(--btn-regular-bg);
    color: var(--btn-content);
    font-size: 0.72rem;
    font-weight: 500;
    line-height: 1;
    transition:
      background-color 150ms ease,
      color 150ms ease;
  }

  .collections-tab-button:hover .collections-tab-count {
    background: var(--btn-regular-bg-hover);
    color: var(--primary);
  }

  .collections-tab-button[data-active="true"] .collections-tab-count {
    background: var(--btn-regular-bg-hover);
    color: var(--primary);
  }

  :global(.dark) .collections-tab-button {
    color: rgb(255 255 255 / 0.54);
  }

  :global(.dark) .collections-tab-button:hover {
    color: rgb(255 255 255 / 0.76);
  }
</style>
