---
import type { UserSubjectCollection } from "@/types/bangumi";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";

interface Props {
	item: UserSubjectCollection;
	subjectType?: number;
}

const { item, subjectType } = Astro.props;

const subject_base_url = "https://bgm.tv/subject/";

const getStatusColor = (type: number) => {
	switch (type) {
		case 1:
			return "bg-blue-500";
		case 2:
			return "bg-green-500";
		case 3:
			return "bg-yellow-500";
		case 4:
			return "bg-orange-500";
		case 5:
			return "bg-red-500";
		default:
			return "bg-gray-500";
	}
};

const getStatusText = (type: number) => {
	const isGame = subjectType === 4;
	const isReal = subjectType === 6;

	if (isGame) {
		switch (type) {
			case 1:
				return i18n(I18nKey.bangumiGameWish);
			case 2:
				return i18n(I18nKey.bangumiGameCompleted);
			case 3:
				return i18n(I18nKey.bangumiGameInProgress);
			case 4:
				return i18n(I18nKey.bangumiGameOnHold);
			case 5:
				return i18n(I18nKey.bangumiGameDropped);
		}
	}

	if (isReal) {
		switch (type) {
			case 1:
				return i18n(I18nKey.bangumiRealWish);
			case 2:
				return i18n(I18nKey.bangumiRealCompleted);
			case 3:
				return i18n(I18nKey.bangumiRealInProgress);
			case 4:
				return i18n(I18nKey.bangumiRealOnHold);
			case 5:
				return i18n(I18nKey.bangumiRealDropped);
		}
	}

	// Default (Anime/Other)
	switch (type) {
		case 1:
			return i18n(I18nKey.bangumiWish);
		case 2:
			return i18n(I18nKey.bangumiCompleted);
		case 3:
			return i18n(I18nKey.bangumiInProgress);
		case 4:
			return i18n(I18nKey.bangumiOnHold);
		case 5:
			return i18n(I18nKey.bangumiDropped);
		default:
			return i18n(I18nKey.bangumiUnknown);
	}
};

const title = item.subject.name || item.subject.name_cn;
---

<a
  href={`${subject_base_url}${item.subject.id}`}
  target="_blank"
  rel="noopener noreferrer nofollow"
  class="group relative overflow-hidden rounded-xl bg-white dark:bg-[oklch(0.28_0.02_var(--hue))] shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-[1.02] block border border-transparent dark:border-white/5"
>
  <div class="aspect-[2/3] relative overflow-hidden" >
    {item.subject?.images?.medium ? (
      <img
        src={item.subject.images.medium}
        alt={title}
        class="w-full h-full object-cover pointer-events-none transition-transform duration-500 group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-gray-200 dark:bg-black/40 flex items-center justify-center">
        <div class="text-gray-400 text-4xl">📖</div>
      </div>
    )}

    <div class={`absolute top-2 left-2 z-10 px-2 py-1 rounded-full text-[10px] text-white font-bold uppercase tracking-wider ${getStatusColor(item.type)} shadow-sm`}>
      {getStatusText(item.type)}
    </div>

    <!-- Overlay (深黑色背景) -->
    <div class="absolute inset-0 z-20 bg-white dark:bg-[oklch(0.32_0.02_var(--hue))] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-300 ease-out flex flex-col shadow-2xl">
      <div class="flex-1 p-5 sm:p-6 flex flex-col justify-center text-center scale-90 group-hover:scale-100 transition-transform duration-300 ease-out origin-center overflow-hidden h-full">
        <h3 class="font-bold text-base sm:text-lg mb-3 sm:mb-4 text-gray-900 dark:text-gray-100 line-clamp-2 shrink-0">
          {title}
        </h3>

        <div class="flex items-center justify-center mb-4">
          {item.rate && item.rate > 0 ? (
            <div class="flex items-center gap-1">
              <div class="text-yellow-400 text-lg">⭐</div>
              <span class="font-bold text-gray-700 dark:text-gray-200 text-base">
                {item.rate}
              </span>
            </div>
          ) : (
            <span class="text-sm italic opacity-40 text-gray-700 dark:text-gray-200">
              Unrated
            </span>
          )}
        </div>

        <div class="flex-1 overflow-y-auto no-scrollbar overscroll-contain touch-pan-y" style="transform: translateZ(0);">
          {item.comment ? (
            <div class="relative py-1 sm:py-2">
              <div class="text-[oklch(0.75_0.14_var(--hue))] text-[10px] font-black mb-2 sm:mb-3 uppercase tracking-[0.2em] opacity-80">{i18n(I18nKey.bangumiMyComment)}</div>
              <p class="text-[13px] italic text-gray-700 dark:text-gray-200 leading-relaxed px-1 sm:px-2 font-serif">
                “{item.comment}”
              </p>
            </div>
          ) : (
            <div class="h-full flex flex-col items-center justify-center opacity-40 text-gray-700 dark:text-gray-200">
              <p class="text-[10px] uppercase tracking-widest font-bold italic">{i18n(I18nKey.bangumiNoComments)}</p>
            </div>
          )}
        </div>

        <div class="mt-3 sm:mt-4 pt-3 sm:pt-4 border-t border-gray-100 dark:border-white/10 shrink-0">
          <span class="text-[9px] text-gray-400 dark:text-gray-400 uppercase tracking-[0.2em] font-bold font-mono">{i18n(I18nKey.bangumiViewOnBangumi)}</span>
        </div>
      </div>
    </div>
  </div>
</a>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
