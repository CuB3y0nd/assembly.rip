---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { UserSubjectCollection } from "@/types/bangumi";

interface Props {
	item: UserSubjectCollection;
	subjectType?: number;
}

const { item, subjectType } = Astro.props;

const subjectBaseUrl = "https://bgm.tv/subject/";

const getStatusColor = (type: number) => {
	switch (type) {
		case 1:
			return "bg-blue-500";
		case 2:
			return "bg-green-500";
		case 3:
			return "bg-yellow-500";
		case 4:
			return "bg-orange-500";
		case 5:
			return "bg-red-500";
		default:
			return "bg-gray-500";
	}
};

const getStatusText = (type: number) => {
	const isGame = subjectType === 4;
	const isReal = subjectType === 6;

	if (isGame) {
		switch (type) {
			case 1:
				return i18n(I18nKey.bangumiGameWish);
			case 2:
				return i18n(I18nKey.bangumiGameCompleted);
			case 3:
				return i18n(I18nKey.bangumiGameInProgress);
			case 4:
				return i18n(I18nKey.bangumiGameOnHold);
			case 5:
				return i18n(I18nKey.bangumiGameDropped);
		}
	}

	if (isReal) {
		switch (type) {
			case 1:
				return i18n(I18nKey.bangumiRealWish);
			case 2:
				return i18n(I18nKey.bangumiRealCompleted);
			case 3:
				return i18n(I18nKey.bangumiRealInProgress);
			case 4:
				return i18n(I18nKey.bangumiRealOnHold);
			case 5:
				return i18n(I18nKey.bangumiRealDropped);
		}
	}

	switch (type) {
		case 1:
			return i18n(I18nKey.bangumiWish);
		case 2:
			return i18n(I18nKey.bangumiCompleted);
		case 3:
			return i18n(I18nKey.bangumiInProgress);
		case 4:
			return i18n(I18nKey.bangumiOnHold);
		case 5:
			return i18n(I18nKey.bangumiDropped);
		default:
			return i18n(I18nKey.bangumiUnknown);
	}
};

const title =
	item.subject.name_cn || item.subject.name || i18n(I18nKey.bangumiUnknown);
const subtitle =
	item.subject.name &&
	item.subject.name_cn &&
	item.subject.name !== item.subject.name_cn
		? item.subject.name
		: "";
const comment = item.comment?.trim() || "";
const score = item.rate && item.rate > 0 ? item.rate : null;
---

<a
	href={`${subjectBaseUrl}${item.subject.id}`}
	target="_blank"
	rel="noopener noreferrer nofollow"
	class="collection-card card-base group block h-full"
>
	<div class="collection-card-media">
		{item.subject?.images?.medium ? (
			<img
				src={item.subject.images.medium}
				alt={title}
				class="collection-card-image"
				loading="lazy"
			/>
		) : (
			<div class="collection-card-fallback">
				<Icon
					name="material-symbols:menu-book-rounded"
					class="text-[2.2rem] text-[var(--primary)]"
				/>
			</div>
		)}

		<div class="collection-card-status">
			<span class:list={["collection-card-status-dot", getStatusColor(item.type)]}></span>
			<span>{getStatusText(item.type)}</span>
		</div>
	</div>

	<div class="collection-card-body">
		<div class:list={["collection-card-header", { "justify-end": !score }]}>
			{score && (
				<div class="collection-card-score">
					<Icon name="material-symbols:star-rounded" class="text-[1rem]" />
					<span>{score}</span>
				</div>
			)}

			<div class="collection-card-link-hint">
				<span>Bangumi</span>
				<Icon
					name="material-symbols:arrow-outward-rounded"
					class="text-[1rem]"
				/>
			</div>
		</div>

		<div class="collection-card-title-block">
			<h3 class="collection-card-title">{title}</h3>
			{subtitle && <p class="collection-card-subtitle">{subtitle}</p>}
		</div>

		<p class:list={["collection-card-summary", { "is-empty": !comment }]}>
			{comment ? `“${comment}”` : i18n(I18nKey.bangumiNoComments)}
		</p>
	</div>
</a>

<style>
	.collection-card {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid var(--line-color);
		border-radius: calc(var(--radius-large) + 0.1rem);
		box-shadow: 0 18px 40px -34px rgb(0 0 0 / 0.35);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.collection-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--primary) 18%, var(--line-color));
		box-shadow: 0 24px 48px -36px rgb(0 0 0 / 0.42);
	}

	.collection-card-media {
		position: relative;
		aspect-ratio: 1 / 1.18;
		overflow: hidden;
		background: linear-gradient(180deg, var(--btn-regular-bg), transparent);
	}

	.collection-card-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 320ms ease;
	}

	.collection-card:hover .collection-card-image {
		transform: scale(1.04);
	}

	.collection-card-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		background:
			radial-gradient(circle at top, rgb(255 255 255 / 0.45), transparent 60%),
			var(--btn-regular-bg);
	}

	.collection-card-status {
		position: absolute;
		top: 0.8rem;
		left: 0.8rem;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-height: 2rem;
		padding: 0.35rem 0.7rem;
		border-radius: 0.7rem;
		background: rgb(255 255 255 / 0.88);
		color: rgb(0 0 0 / 0.72);
		font-size: 0.74rem;
		font-weight: 600;
		line-height: 1;
		backdrop-filter: blur(12px);
		box-shadow: 0 10px 24px -18px rgb(0 0 0 / 0.42);
	}

	.collection-card-status-dot {
		display: inline-block;
		width: 0.52rem;
		height: 0.52rem;
		border-radius: 999px;
		flex-shrink: 0;
	}

	.collection-card-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		gap: 0.7rem;
		padding: 1rem;
	}

	.collection-card-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.collection-card-score {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		height: 1.8rem;
		padding: 0 0.65rem;
		border-radius: 0.65rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.76rem;
		font-weight: 600;
		line-height: 1;
	}

	.collection-card-link-hint {
		display: inline-flex;
		align-items: center;
		gap: 0.18rem;
		margin-left: auto;
		color: rgb(0 0 0 / 0.34);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		transition: color 180ms ease, transform 180ms ease;
	}

	.collection-card:hover .collection-card-link-hint {
		color: var(--primary);
		transform: translateX(1px);
	}

	.collection-card-title-block {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.collection-card-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.35;
		color: rgb(0 0 0 / 0.82);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-subtitle {
		font-size: 0.8rem;
		color: rgb(0 0 0 / 0.42);
		line-height: 1.45;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-summary {
		margin-top: auto;
		font-size: 0.85rem;
		line-height: 1.7;
		color: rgb(0 0 0 / 0.62);
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.collection-card-summary.is-empty {
		font-style: italic;
		color: rgb(0 0 0 / 0.38);
	}

	:global(.dark) .collection-card {
		box-shadow: none;
	}

	:global(.dark) .collection-card-status {
		background: rgb(24 24 27 / 0.8);
		color: rgb(255 255 255 / 0.76);
	}

	:global(.dark) .collection-card-title {
		color: rgb(255 255 255 / 0.86);
	}

	:global(.dark) .collection-card-subtitle {
		color: rgb(255 255 255 / 0.42);
	}

	:global(.dark) .collection-card-summary {
		color: rgb(255 255 255 / 0.62);
	}

	:global(.dark) .collection-card-summary.is-empty {
		color: rgb(255 255 255 / 0.34);
	}

	:global(.dark) .collection-card-link-hint {
		color: rgb(255 255 255 / 0.32);
	}
</style>
