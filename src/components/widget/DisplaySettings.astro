---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";
---

<div
  id="display-setting"
  data-display-settings
  data-default-hue={siteConfig.themeColor.hue}
  class="float-panel float-panel-closed absolute transition-all w-80 right-4 px-4 py-4"
>
  <div class="flex flex-row gap-2 mb-3 items-center justify-between">
    <div
      class="flex gap-2 font-bold text-lg text-neutral-900 dark:text-neutral-100 transition relative ml-3
            before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
            before:absolute before:-left-3 before:top-[0.33rem]"
    >
      {i18n(I18nKey.themeColor)}
      <button
        aria-label="Reset to Default"
        data-display-reset
        class="btn-regular w-7 h-7 rounded-md active:scale-90 will-change-transform"
      >
        <div class="text-[var(--btn-content)]">
          <Icon name="fa6-solid:arrow-rotate-left" class="text-[0.875rem]" />
        </div>
      </button>
    </div>
    <div class="flex gap-1">
      <div
        data-display-hue-value
        class="transition bg-[var(--btn-regular-bg)] w-10 h-7 rounded-md flex justify-center
            font-bold text-sm items-center text-[var(--btn-content)]"
      >
        {siteConfig.themeColor.hue}
      </div>
    </div>
  </div>
  <div
    class="w-full h-6 px-1 bg-[oklch(0.80_0.10_0)] dark:bg-[oklch(0.70_0.10_0)] rounded select-none"
  >
    <input
      aria-label={i18n(I18nKey.themeColor)}
      data-display-slider
      type="range"
      min="0"
      max="360"
      value={siteConfig.themeColor.hue}
      class="slider"
      id="colorSlider"
      step="5"
      style="width: 100%"
    />
  </div>
</div>

<script>
import { getDefaultHue, getHue, setHue } from "@utils/setting-utils";

function initDisplaySettings(root: Element): void {
	if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") {
		return;
	}
	root.dataset.initialized = "true";

	const slider = root.querySelector("[data-display-slider]");
	const hueValue = root.querySelector("[data-display-hue-value]");
	const resetButton = root.querySelector("[data-display-reset]");
	if (
		!(slider instanceof HTMLInputElement) ||
		!(hueValue instanceof HTMLElement) ||
		!(resetButton instanceof HTMLButtonElement)
	) {
		return;
	}

	const defaultHue = getDefaultHue();
	let hue = getHue();

	const updateUi = (): void => {
		hueValue.textContent = String(hue);
		slider.value = String(hue);
		const isDefault = hue === defaultHue;
		resetButton.classList.toggle("opacity-0", isDefault);
		resetButton.classList.toggle("pointer-events-none", isDefault);
	};

	const applyHueValue = (nextHue: number): void => {
		hue = nextHue;
		setHue(hue);
		updateUi();
	};

	slider.addEventListener("input", () => {
		applyHueValue(Number.parseInt(slider.value, 10));
	});

	resetButton.addEventListener("click", () => {
		applyHueValue(defaultHue);
	});

	updateUi();
}

function initAllDisplaySettings(): void {
	document.querySelectorAll("[data-display-settings]").forEach(initDisplaySettings);
}

if (document.readyState === "loading") {
	document.addEventListener("DOMContentLoaded", initAllDisplaySettings, {
		once: true,
	});
} else {
	initAllDisplaySettings();
}

document.addEventListener("astro:page-load", initAllDisplaySettings);
</script>

<style>
  #display-setting input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    height: 1.5rem;
    background-image: var(--color-selection-bar);
    transition: background-image 0.15s ease-in-out;
  }

  #display-setting input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    height: 1rem;
    width: 0.5rem;
    border-radius: 0.125rem;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: none;
  }

  #display-setting input[type="range"]::-webkit-slider-thumb:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  #display-setting input[type="range"]::-webkit-slider-thumb:active {
    background: rgba(255, 255, 255, 0.6);
  }

  #display-setting input[type="range"]::-moz-range-thumb {
    -webkit-appearance: none;
    appearance: none;
    height: 1rem;
    width: 0.5rem;
    border-radius: 0.125rem;
    border-width: 0;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: none;
  }

  #display-setting input[type="range"]::-moz-range-thumb:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  #display-setting input[type="range"]::-moz-range-thumb:active {
    background: rgba(255, 255, 255, 0.6);
  }

  #display-setting input[type="range"]::-ms-thumb {
    -webkit-appearance: none;
    appearance: none;
    height: 1rem;
    width: 0.5rem;
    border-radius: 0.125rem;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: none;
  }

  #display-setting input[type="range"]::-ms-thumb:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  #display-setting input[type="range"]::-ms-thumb:active {
    background: rgba(255, 255, 255, 0.6);
  }
</style>
