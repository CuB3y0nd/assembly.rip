---
import BangumiSection from "@/components/bangumi/BangumiSection.astro";
import Pagination from "@/components/bangumi/Pagination.astro";
import TabNav from "@/components/bangumi/TabNav.astro";
import ZoteroSection from "@/components/zotero/ZoteroSection.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import type { ZoteroItem } from "@/types/zotero";
import { type BangumiConfig, fetchBangumiData } from "@/utils/bangumi";
import { fetchZoteroData, type ZoteroConfig } from "@/utils/zotero";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";

const bangumiUsername = process.env.BANGUMI_USERNAME;
const zoteroUserID = process.env.ZOTERO_USER_ID;
const zoteroKey = process.env.ZOTERO_KEY;

const bangumiConfig: BangumiConfig = {
	username: `${bangumiUsername}`,
	apiUrl: "https://api.bgm.tv",
	pagination: {
		limit: 50,
		delay: 50,
		maxTotal: 1000,
	},
};

const enabledBangumiCategories = {
	book: false,
	anime: true,
	music: false,
	game: false,
	real: true,
};

const zoteroConfig: ZoteroConfig = {
	userId: `${zoteroUserID}`,
	apiKey: `${zoteroKey}`,
	limit: 100,
};

const categoryMap = {
	book: { id: "book", name: i18n(I18nKey.collectionsBook), subjectType: 1 },
	anime: { id: "anime", name: i18n(I18nKey.collectionsAnime), subjectType: 2 },
	music: { id: "music", name: i18n(I18nKey.collectionsMusic), subjectType: 3 },
	game: { id: "game", name: i18n(I18nKey.collectionsGame), subjectType: 4 },
	real: { id: "real", name: i18n(I18nKey.collectionsReal), subjectType: 6 },
};

// Get data for all enabled categories
const bangumiData: Record<string, UserSubjectCollection[]> = {};
let zoteroData: ZoteroItem[] = [];
const tabs: Array<{
	id: string;
	name: string;
	count: number;
	type: "bangumi" | "zotero";
}> = [];

console.log("[Collections] Starting to fetch all data");

// Fetch Zotero data and add to tabs
try {
	zoteroData = await fetchZoteroData(zoteroConfig);
	if (zoteroData.length > 0) {
		tabs.push({
			id: "zotero",
			name: i18n(I18nKey.collectionsZotero),
			count: zoteroData.length,
			type: "zotero",
		});
	}
} catch (error) {
	console.error("[Zotero] Initialization failed:", error);
}

for (const [categoryKey, enabled] of Object.entries(enabledBangumiCategories)) {
	if (enabled && categoryMap[categoryKey as keyof typeof categoryMap]) {
		const categoryInfo = categoryMap[categoryKey as keyof typeof categoryMap];
		try {
			const data = await fetchBangumiData(
				bangumiConfig,
				categoryInfo.subjectType,
			);
			bangumiData[categoryKey] = data;
			tabs.push({
				id: categoryKey,
				name: categoryInfo.name,
				count: data.length,
				type: "bangumi",
			});
		} catch (error) {
			console.error(`[Bangumi] Failed to fetch ${categoryInfo.name} data:`, error);
			bangumiData[categoryKey] = [];
			tabs.push({
				id: categoryKey,
				name: categoryInfo.name,
				count: 0,
				type: "bangumi",
			});
		}
	}
}

const activeTab = tabs[0]?.id || "zotero";
---

<MainGridLayout title={i18n(I18nKey.collections)} description={"My Collections from Bangumi and Zotero"}>
  <div class="flex flex-col w-full gap-4 mb-4">
    <div class="card-base px-9 py-6 relative w-full">
      <h1 class="text-3xl font-bold text-90 mb-4">
        {i18n(I18nKey.collections)}
      </h1>

      <!-- Tab Navigation and Content -->
      {tabs.length > 0 ? (
        <>
          <TabNav tabs={tabs} activeTab={activeTab} />

            <!-- Content Area -->
            {tabs.map((tab) => (
              tab.type === "bangumi" ? (
                <BangumiSection
                  sectionId={tab.id}
                  items={bangumiData[tab.id] || []}
                  isActive={tab.id === activeTab}
                  itemsPerPage={6}
                />
              ) : (
                <ZoteroSection
                  sectionId={tab.id}
                  items={zoteroData}
                  isActive={tab.id === activeTab}
                  itemsPerPage={6}
                />
              )
            ))}
          </>
        ) : (
          <div class="text-center py-12">
            <h2 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-2">
              {i18n(I18nKey.collectionsNoData)}
            </h2>
            <p class="text-gray-500 dark:text-gray-400 mb-4">
              {i18n(I18nKey.collectionsNoDataReason)}
            </p>
            <div class="text-sm text-gray-400 dark:text-gray-500 space-y-1">
              <div>{i18n(I18nKey.collectionsUsername)}: {bangumiConfig.username}</div>
              <div>{i18n(I18nKey.collectionsApi)}: {bangumiConfig.apiUrl}</div>
              <div class="mt-3 text-xs">
                {i18n(I18nKey.collectionsHint)}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>

    {tabs.map((tab) => (
      <div class:list={[{ "hidden": tab.id !== activeTab }]} data-section={tab.id}>
        <Pagination
          totalItems={tab.type === "bangumi" ? (bangumiData[tab.id]?.length || 0) : zoteroData.length}
          itemsPerPage={tab.type === "bangumi" ? 6 : 9}
          currentPage={1}
          sectionId={tab.id}
        />
      </div>
    ))}
  </div>
</MainGridLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
